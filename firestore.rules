rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user can read a user doc (needed for friend profiles / passports).
    // Only the owner can do a full write.
    // Exception: any authenticated user may append their own UID to another user's friendIds
    // (the "mutual friend add" flow — scanning a QR code).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendIds'])
        && request.resource.data.friendIds.hasAll(resource.data.get('friendIds', []))
        && request.resource.data.friendIds.size() == resource.data.get('friendIds', []).size() + 1
        && request.auth.uid in request.resource.data.friendIds;
    }

    // Anonymised per-pub aggregates powering the public heatmap.
    // Any authed user can read or update (no userIds stored), but shape is tightly validated.
    match /pubStats/{placeId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['placeId','pubName','lat','lng','totalRating','pintCount','avgRating','lastUpdated'])
        && request.resource.data.placeId == placeId
        && request.resource.data.pintCount == 1
        && request.resource.data.totalRating >= 1
        && request.resource.data.totalRating <= 5
        && request.resource.data.avgRating >= 1
        && request.resource.data.avgRating <= 5;

      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['totalRating','pintCount','avgRating','trailEligible','lastUpdated','pubName','lat','lng'])
        && request.resource.data.pintCount >= 0
        && (request.resource.data.pintCount - resource.data.pintCount) >= -1
        && (request.resource.data.pintCount - resource.data.pintCount) <= 1
        && request.resource.data.totalRating >= 0
        && request.resource.data.avgRating >= 0
        && request.resource.data.avgRating <= 5;

      allow delete: if false;
    }

    // Pilgrimage trails — curated (hand-authored) and organic (generated nightly
    // by the generateOrganicTrails Cloud Function). All reads are public to
    // authed users; all writes are blocked from clients because the Cloud
    // Function runs with admin privileges and bypasses rules anyway.
    match /pilgrimages/{pilgrimageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Pints are readable by the owner OR by any of the owner's friends
    // (but only when the owner has opted in to sharing with friends).
    match /pints/{pintId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('friendIds', []) &&
          get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('shareWithFriends', true) == true
        )
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
